# ==============================================================================
# NasFusion 本地/源码部署配置
# ==============================================================================
# ⚠️ 重要提示：
#   - 本地/源码部署请使用此文件（backend/.env.example）
#   - Docker 部署请使用项目根目录的 .env.example
#   - 两者只需一个，不要同时配置
#
# 使用步骤：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改所有 🔴【必须修改】项
# 3. 根据实际情况调整 🟡【建议修改】项
# 4. ⚪【可选】项保持默认即可
# 5. 运行：python -m app.main:app
# ==============================================================================

# ==============================================================================
# 🔴 【必须修改】安全密钥（启动前务必设置！）
# ==============================================================================

# SECRET_KEY: 应用主密钥，用于加密敏感数据（至少32字符）
# 生成命令：openssl rand -hex 32
SECRET_KEY=请执行 openssl rand -hex 32 生成并替换此文本

# JWT_SECRET_KEY: JWT令牌签名密钥（建议与SECRET_KEY不同）
# 生成命令：openssl rand -hex 32
JWT_SECRET_KEY=请执行 openssl rand -hex 32 生成并替换此文本

# ==============================================================================
# 🟡 【建议修改】数据库选择（SQLite 或 PostgreSQL）
# ==============================================================================
# 说明：
#   - sqlite: 零配置，适合快速体验/开发（数据保存在本地文件）
#   - postgresql: 生产环境推荐，性能更好

DB_TYPE=sqlite

# --- SQLite 配置（当 DB_TYPE=sqlite 时使用）---
DB_SQLITE_PATH=./data/nasfusion.db

# --- PostgreSQL 配置（当 DB_TYPE=postgresql 时使用）---
# ⚠️ 使用 PostgreSQL 时必须修改以下密码！
DB_POSTGRES_PASSWORD=请设置安全的数据库密码

# 其他 PostgreSQL 配置（一般无需修改）
DB_POSTGRES_SERVER=localhost
DB_POSTGRES_USER=nasfusion
DB_POSTGRES_DB=nasfusion
DB_POSTGRES_PORT=5432

# ==============================================================================
# ⚪ 【可选】Redis 配置（当前未启用，保持默认即可）
# ==============================================================================
# 说明：Redis 当前版本暂未启用，配置保留供后续版本使用

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==============================================================================
# ⚪ 【可选】应用基础配置（一般无需修改）
# ==============================================================================

APP_NAME=NasFusion
APP_VERSION=0.1.0
DEBUG=false
ALLOWED_HOSTS=["*"]
API_V1_PREFIX=/api/v1

# ==============================================================================
# ⚪ 【可选】JWT 配置（一般无需修改）
# ==============================================================================

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==============================================================================
# ⚪ 【可选】文件路径（保持默认即可）
# ==============================================================================
# 说明：下载目录和媒体库路径在启动后通过 Web 界面"存储设置"配置

TORRENT_PATH=./data/torrents
LOG_PATH=./data/logs

# ==============================================================================
# ⚪ 【可选】时区与日志（一般无需修改）
# ==============================================================================

TIMEZONE=Asia/Shanghai
TIMEZONE_OFFSET=+08:00
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==============================================================================
# ⚪ 【可选】豆瓣 API（已内置公开密钥，一般无需配置）
# ==============================================================================
# 如遇访问限制，可尝试更换其他公开密钥

# DOUBAN_API_KEY=0dad551ec0f84ed02907ff5c42e8ec70
# DOUBAN_API_KEY2=0ab215a8b1977939201640fa14c66bab
# DOUBAN_API_SECRET=bf7dddc7c9cfe6f7
