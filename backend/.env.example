# Application
APP_NAME=NasFusion
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=["*"]

# API
API_V1_PREFIX=/api/v1

# Database Configuration
DB_TYPE=sqlite  # sqlite or postgresql

# SQLite Configuration (used when DB_TYPE=sqlite)
DB_SQLITE_PATH=./data/nasfusion.db

# PostgreSQL Configuration (used when DB_TYPE=postgresql)
DB_POSTGRES_SERVER=localhost
DB_POSTGRES_USER=nasfusion
DB_POSTGRES_PASSWORD=your-password-here
DB_POSTGRES_DB=nasfusion
DB_POSTGRES_PORT=5432


# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0


# Security
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Paths
TORRENT_PATH=./data/torrents
LOG_PATH=./data/logs





# Timezone Configuration
# 说明：数据库直接存储本地时间，便于维护和调试
# TIMEZONE用于时间格式化显示，不影响数据库存储
TIMEZONE=Asia/Shanghai  # 系统默认时区，用于时间显示格式化
TIMEZONE_OFFSET=+08:00  # 时区偏移量（仅供参考）

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ==============================================================================
# 豆瓣 API 配置（可选，已内置开源社区公开密钥）
# ==============================================================================
# 说明：以下为豆瓣 Frodo 移动端 API 的公开密钥，来自开源社区
# 如果遇到访问限制，可以尝试替换为其他公开密钥
# DOUBAN_API_KEY=0dad551ec0f84ed02907ff5c42e8ec70
# DOUBAN_API_KEY2=0ab215a8b1977939201640fa14c66bab
# DOUBAN_API_SECRET=bf7dddc7c9cfe6f7

# ==============================================================================
# 存储路径配置（本地/源码部署）
# ==============================================================================
# 说明：
# 1. 本地部署模式下，下载目录和媒体库路径在 Web 界面的"存储设置"中配置
# 2. 此处仅定义默认数据目录
# 3. Docker 部署请使用项目根目录的 .env 文件
# ==============================================================================

# 默认数据目录（本地模式）
# 下载目录和媒体库路径可在启动后通过 Web 界面配置
# STORAGE_DOWNLOAD_PATHS=./data/downloads
# STORAGE_LIBRARY_PATHS=./data/library/movies:movie:true,./data/library/tv:tv:true
