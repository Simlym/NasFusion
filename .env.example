# ==============================================================================
# NasFusion Docker Compose 部署配置
# ==============================================================================
# ⚠️ 重要提示：
#   - Docker 部署请使用此文件（项目根目录 .env）
#   - 本地/源码部署请使用 backend/.env.example
#   - 两者只需一个，不要同时配置
#
# 使用步骤：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改所有 🔴【必须修改】项
# 3. 根据实际情况调整 🟡【建议修改】项
# 4. ⚪【可选】项保持默认即可
# 5. 运行：docker-compose up -d
# ==============================================================================

# ==============================================================================
# 🔴 【必须修改】安全密钥（启动前务必设置！）
# ==============================================================================

# SECRET_KEY: 应用主密钥，用于加密敏感数据（至少32字符）
# 生成命令：openssl rand -hex 32
SECRET_KEY=请执行 openssl rand -hex 32 生成并替换此文本

# JWT_SECRET_KEY: JWT令牌签名密钥（建议与SECRET_KEY不同）
# 生成命令：openssl rand -hex 32
JWT_SECRET_KEY=请执行 openssl rand -hex 32 生成并替换此文本

# ==============================================================================
# 🔴 【必须修改】数据库密码
# ==============================================================================
# Docker 环境使用 PostgreSQL，必须设置密码

DB_POSTGRES_PASSWORD=请设置安全的数据库密码

# ==============================================================================
# 🟡 【建议修改】用户权限（根据你的NAS系统调整）
# ==============================================================================
# 执行 `id` 命令查看你的UID/GID：
#   - 群晖 DSM: 通常是 1024:100
#   - 威联通: 通常是 1000:1000
#   - 其他Linux: 通常是 1000:1000

PUID=0
PGID=0

# ==============================================================================
# 🟡 【建议修改】存储卷路径（根据你的NAS实际路径调整）
# ==============================================================================
# 说明：将NAS物理卷整体挂载到容器，可以确保硬链接正常工作
# 硬链接只能在同一文件系统内创建，所以下载目录和媒体库需要在同一卷
# 提前规划目录结构，每个盘符下创建下载和媒体目录，例如：
# /volume1/downloads 和 /volume1/library/tv、movies 等
# /volume2/downloads 和 /volume2/library/tv、movies 等

# 主存储卷（必须配置）
VOLUME_1_PATH=/volume1

# 扩展存储卷（如有多卷NAS，取消注释并配置）
# VOLUME_2_PATH=/volume2
# VOLUME_3_PATH=/volume3

# ==============================================================================
# ⚪ 【可选】网络端口（如无冲突保持默认）
# ==============================================================================

# Web 访问端口（NAS的80通常被占用，建议保持8080）
HTTP_PORT=8080

# ==============================================================================
# ⚪ 【可选】镜像源
# ==============================================================================
# 默认从 Docker Hub 拉取；如需备用源可改为 GHCR：
#   GHCR（备用）: IMAGE_REGISTRY=ghcr.io/simlym
IMAGE_REGISTRY=docker.io/simlym
# 镜像版本（latest 为最新，亦可锁定到具体版本如 v0.1.0）
IMAGE_TAG=latest

# ==============================================================================
# ⚪ 【可选】应用配置（一般无需修改）
# ==============================================================================

APP_NAME=NasFusion
# 注：应用版本号（APP_VERSION）由镜像构建时自动注入（取自 Git tag），无需在此配置
DEBUG=false
API_V1_PREFIX=/api/v1

# JWT 配置
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================================================
# ⚪ 【可选】其他数据库配置（Docker环境保持默认）
# ==============================================================================

DB_TYPE=postgresql
DB_POSTGRES_USER=nasfusion
DB_POSTGRES_DB=nasfusion
DB_POSTGRES_SERVER=postgres
DB_POSTGRES_PORT=5432

# ==============================================================================
# 🟡 【建议修改】第三方 API Key
# ==============================================================================
# TMDB API Key：用于电影/电视剧元数据刮削（强烈建议配置）
# 获取地址：https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OpenAI API Key：用于 AI 助手（可选，留空则禁用 AI 功能）
OPENAI_API_KEY=

# ==============================================================================
# ⚪ 【可选】日志与时区（一般无需修改）
# ==============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
TZ=Asia/Shanghai

# ==============================================================================
# ⚪ 【可选】应用数据目录（保持默认即可）
# ==============================================================================
# 这些目录会自动在项目 data/ 目录下创建

TORRENT_PATH=./data/torrents
LOG_PATH=./data/logs
CACHE_PATH=./data/cache
