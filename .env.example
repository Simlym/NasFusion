# ==============================================================================
# NasFusion Docker Compose 环境变量配置模板
# ==============================================================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改配置项以适配你的环境
# 3. 运行：docker-compose up -d
# ==============================================================================

# ------------------------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------------------------
APP_NAME=NasFusion
APP_VERSION=0.1.0
# 生产环境务必设置为 false
DEBUG=false
API_V1_PREFIX=/api/v1

# ------------------------------------------------------------------------------
# 安全配置（⚠️ 必须修改！）
# ------------------------------------------------------------------------------
# SECRET_KEY: 应用级主密钥，用于加密敏感数据（至少32字符）
# 生成方法：openssl rand -hex 32
SECRET_KEY=请设置至少32字符的随机密钥

# JWT_SECRET_KEY: JWT 令牌签名密钥（建议与 SECRET_KEY 不同）
# 生成方法：openssl rand -hex 32
JWT_SECRET_KEY=请设置至少32字符的随机密钥

# JWT 配置
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# 数据库配置（PostgreSQL）
# ------------------------------------------------------------------------------
# 数据库类型（Docker 环境使用 postgresql）
DB_TYPE=postgresql

# PostgreSQL 连接配置
DB_POSTGRES_USER=nasfusion
DB_POSTGRES_PASSWORD=请设置安全的数据库密码  # ⚠️ 必须修改！
DB_POSTGRES_DB=nasfusion
DB_POSTGRES_SERVER=postgres  # Docker 网络中的服务名
DB_POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Redis 配置
# ------------------------------------------------------------------------------
REDIS_HOST=redis  # Docker 网络中的服务名
REDIS_PORT=6379
REDIS_DB=0

# ------------------------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json 或 text

# ------------------------------------------------------------------------------
# 时区配置
# ------------------------------------------------------------------------------
TZ=Asia/Shanghai  # 容器时区，示例: Asia/Shanghai, America/New_York

# ------------------------------------------------------------------------------
# 用户权限配置
# ------------------------------------------------------------------------------
# 执行 `id` 命令查看你的 UID/GID
# 群晖默认通常是 1024:100 或 1000:1000
# 威联通默认通常是 1000:1000
PUID=1024
PGID=100

# ------------------------------------------------------------------------------
# 端口配置
# ------------------------------------------------------------------------------
# HTTP 端口（NAS 的 80 端口通常被系统占用，建议使用 8080）
HTTP_PORT=8080

# PostgreSQL 外部访问端口
# 默认 5432，如果宿主机已有 PostgreSQL 运行，建议改为 5433
# ⚠️ 安全提示：生产环境建议不暴露数据库端口，或配置防火墙规则
DB_EXTERNAL_PORT=5432

# ------------------------------------------------------------------------------
# 应用数据目录（使用项目内路径）
# ------------------------------------------------------------------------------
# 这些目录会自动在项目 data/ 下创建，通常不需要修改
TORRENT_PATH=./data/torrents
LOG_PATH=./data/logs
CACHE_PATH=./data/cache

# ------------------------------------------------------------------------------
# 存储卷挂载配置（支持硬链接的关键！）
# ------------------------------------------------------------------------------
# 说明：
# 1. 将 NAS 的物理卷整体挂载到容器，确保同卷内可进行硬链接
# 2. 具体的下载目录和媒体库路径在 Web 界面的"存储设置"中配置
# 3. 未使用的卷可留空或注释
#
# 重要提示：
# - 硬链接只能在同一文件系统（同一卷）内创建
# - 将整个卷挂载可确保下载目录和媒体库目录共享同一设备ID
# - 例如：/volume1/Downloads 和 /volume1/Media 可以硬链接

# ===== 主存储卷 =====
VOLUME_1_PATH=/volume1

# ===== 扩展存储卷（可选）=====
# VOLUME_2_PATH=/volume2
# VOLUME_3_PATH=/volume3
# VOLUME_4_PATH=/volume4
